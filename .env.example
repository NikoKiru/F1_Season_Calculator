# F1 Season Calculator configuration
# Copy to .env and uncomment what you need. Every key maps to a field on
# app/config.py::Settings (pydantic-settings, case-insensitive).

# Serve address
#HOST=127.0.0.1
#PORT=8000

# Verbose FastAPI/debug behavior
#DEBUG=false

# Season shown by default. Unset = newest data/seasons/{YYYY}.json.
#DEFAULT_SEASON=2026

# Custom locations (defaults live under the project root)
#DATABASE_PATH=instance/championships.db
#DATA_FOLDER=data
#SEASONS_FOLDER=data/seasons

# Response cache tuning
#CACHE_TTL_SECONDS=3600
#CACHE_MAXSIZE=1024
